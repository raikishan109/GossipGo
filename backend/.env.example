NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/gossipgo
REDIS_URL=redis://localhost:6379

# User panel URL
USERPANEL_URL=http://localhost:3000

# Admin panel URL
ADMINPANEL_URL=http://localhost:3001

# Optional admin seed credentials
ADMIN_EMAIL=admin@gossipgo.local
ADMIN_PASSWORD=Admin@12345
ADMIN_USERNAME=GossipGoAdmin

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=20
GUEST_MODE_ENABLED=true
